# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Database (required for production)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth (required for JWT - use a long random string in production)
JWT_SECRET=your-super-secret-key-change-in-production

# Optional: Internal API base URL (when server-to-server fetch is needed)
# API_BASE_URL=https://api.yourdomain.com

# Optional: Frontend build-time overrides (VITE_ prefix)
# VITE_DEFAULT_GUEST_COUNT=50
# VITE_DEV_PORT=3000
# VITE_DEV_HOST=localhost
